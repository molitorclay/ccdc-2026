# Nmap
alert tcp $EXTERNAL_NET any -> $HOME_NET any (
    msg:"LOCAL Possible Nmap SYN scan";
    flow:stateless;
    flags:S;
    detection_filter:track by_src,count 20,seconds 5;
    sid:1000001;
    rev:1;
)

alert tcp $EXTERNAL_NET any -> $HOME_NET any (
    msg:"LOCAL Possible Nmap NULL scan";
    flow:stateless;
    flags:0;
    detection_filter:track by_src,count 10,seconds 5;
    sid:1000002;
    rev:1;
)

alert tcp $EXTERNAL_NET any -> $HOME_NET any (
    msg:"LOCAL Possible Nmap FIN scan";
    flow:stateless;
    flags:F;
    detection_filter:track by_src,count 10,seconds 5;
    sid:1000003;
    rev:1;
)

alert tcp $EXTERNAL_NET any -> $HOME_NET any (
    msg:"LOCAL Possible Nmap Xmas scan";
    flow:stateless;
    flags:FPU;
    detection_filter:track by_src,count 10,seconds 5;
    sid:1000004;
    rev:1;
)

alert icmp $EXTERNAL_NET any -> $HOME_NET any (
    msg:"LOCAL Possible Nmap ICMP ping sweep";
    itype:=8;
    icode:=0;
    detection_filter:track by_src,count 10,seconds 5;
    sid:1000005;
    rev:1;
)

# -------------------------------
# SSH brute force / repeated login attempts
# -------------------------------

alert tcp $EXTERNAL_NET any -> $HOME_NET 22 (
    msg:"LOCAL Possible SSH brute force";
    flow:stateless;
    flags:S;
    detection_filter:track by_src,count 15,seconds 60;
    classtype:attempted-user;
    sid:1000201;
    rev:1;
)

# -------------------------------
# Web crawler / scanner user-agents
# -------------------------------

alert tcp $EXTERNAL_NET any -> $HOME_NET any (
    msg:"LOCAL Web scanner user-agent curl";
    flow:to_server,established;
    service:http;
    http_header:field user-agent;
    content:"curl/"; nocase;
    classtype:web-application-attack;
    sid:1000202;
    rev:1;
)

alert tcp $EXTERNAL_NET any -> $HOME_NET any (
    msg:"LOCAL Web scanner user-agent Wget";
    flow:to_server,established;
    service:http;
    http_header:field user-agent;
