# -------------------------------
# Common web recon / exploit path probes
# -------------------------------

alert tcp $EXTERNAL_NET any -> $HOME_NET any (
    msg:"LOCAL Web recon probe .git/config";
    flow:to_server,established;
    service:http;
    http_uri;
    content:"/.git/config"; nocase;
    classtype:web-application-attack;
    sid:1000211;
    rev:1;
)

alert tcp $EXTERNAL_NET any -> $HOME_NET any (
    msg:"LOCAL Web recon probe .env";
    flow:to_server,established;
    service:http;
    http_uri;
    content:"/.env"; nocase;
    classtype:web-application-attack;
    sid:1000212;
    rev:1;
)

